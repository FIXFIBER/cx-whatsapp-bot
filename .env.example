# ── CX WhatsApp Web (server config) ──
# Copy to .env and fill in. Render reads these as env vars too.

# Port the bot listens on (Render sets this automatically)
PORT=3001

# Persistent data dir. On Render this is the mounted disk (/data).
DATA_DIR=/data

# Public base URL of THIS service (used for the Share/Invite QR).
# On Render set it to your service URL, e.g. https://cx-whatsapp-bot.onrender.com
PUBLIC_URL=

# OWNER / HEAD key.
# • If you LEAVE THIS BLANK on a fresh deploy, the first device to open the
#   client and click "Claim as owner" becomes the head (owner) automatically.
# • After that, set this to the generated head key so ONLY you can be head.
#   (Find the key in the client: My Devices → "Head key".)
# ADMIN_KEY=

# Supabase sync (optional). Leave blank to disable DB sync.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
